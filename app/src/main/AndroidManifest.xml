<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />

    <application
        android:name=".MindWellApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MindWell"
        android:usesCleartextTraffic="false">

        <activity
            android:name=".ui.main.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".ui.mood.MoodActivity" android:parentActivityName=".ui.main.MainActivity" />
        <activity android:name=".ui.journal.JournalActivity" android:parentActivityName=".ui.main.MainActivity" />
        <activity android:name=".ui.journal.JournalEditActivity" android:parentActivityName=".ui.journal.JournalActivity" />
        <activity android:name=".ui.breathing.BreathingActivity" android:parentActivityName=".ui.main.MainActivity" />
        <activity android:name=".ui.coping.CopingActivity" android:parentActivityName=".ui.main.MainActivity" />
        <activity android:name=".ui.crisis.CrisisActivity" android:parentActivityName=".ui.main.MainActivity" />
        <activity android:name=".ui.tips.TipsActivity" android:parentActivityName=".ui.main.MainActivity" />
        <activity android:name=".ui.chart.ChartActivity" android:parentActivityName=".ui.main.MainActivity" />
        <activity android:name=".ui.about.AboutActivity" android:parentActivityName=".ui.main.MainActivity" />
        <activity android:name=".ui.reminder.ReminderActivity" android:parentActivityName=".ui.main.MainActivity" />

        <receiver
            android:name=".reminder.ReminderReceiver"
            android:exported="false" />

    </application>
</manifest>